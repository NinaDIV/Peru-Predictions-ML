---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Análisis comparativo de las elecciones presidenciales de Perú 2021 y 2026, contrastando resultados oficiales de ONPE con predicciones de Polymarket.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- SEO Meta Tags -->
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Favicon -->
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🇵🇪</text></svg>"
    />
  </head>
  <body>
    <header class="animated-fade-in" style="margin-bottom: 24px;">
      <div class="google-bar">
        <span class="bar-blue"></span>
        <span class="bar-red"></span>
        <span class="bar-yellow"></span>
        <span class="bar-green"></span>
      </div>
      <div
        style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;"
      >
        <div style="display: flex; align-items: center; gap: 12px;">
          <span style="font-size: 2.5rem;">🇵🇪</span>
          <div>
            <h1 style="font-size: 1.75rem; color: #ffffff; font-weight: 600;">
              Precisión Electoral
            </h1>
            <p style="font-size: 0.875rem;">Perú: 2021 vs. 2026</p>
          </div>
        </div>
      </div>
    </header>

    <main
      class="animated-fade-in"
      style="flex: 1; display: flex; flex-direction: column; gap: 24px;"
    >
      <slot />
    </main>

    <footer
      class="animated-fade-in"
      style="margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--color-border); text-align: center; font-size: 0.875rem; color: var(--text-muted);"
    >
      <p>
        © {new Date().getFullYear()} Precisión Electoral Perú. Análisis de datos desarrollado
        con Astro y APIs de Polymarket.
      </p>
      <p style="font-size: 0.75rem; margin-top: 8px;">
        Este sitio web es de carácter netamente informativo y educativo. Los
        datos de mercados de predicción representan probabilidades especulativas
        sujetas a fluctuación constante.
      </p>
    </footer>
  </body>
</html>
