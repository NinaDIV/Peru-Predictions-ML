---
import Layout from '../layouts/Layout.astro';
import CandidateCard from '../components/CandidateCard.astro';
import ElectionChart from '../components/ElectionChart.astro';

// 2021 Election Data (Official ONPE final results)
const election2021 = {
  castillo: {
    name: "Pedro Castillo",
    party: "Perú Libre",
    votes: "8,836,380",
    percentage: "50.126%",
    initials: "PC",
    color: "#81c995", // Google Green
    bgColor: "rgba(129, 201, 149, 0.12)",
    statusText: "Ganador",
    statusType: "success" as const
  },
  fujimori: {
    name: "Keiko Fujimori",
    party: "Fuerza Popular",
    votes: "8,792,117",
    percentage: "49.874%",
    initials: "KF",
    color: "#8ab4f8", // Google Blue
    bgColor: "rgba(138, 180, 248, 0.12)",
    statusText: "Finalista",
    statusType: "info" as const
  }
};

// 2026 Election Data (ONPE 94% Counted + Polymarket Live Price Snapshot)
const election2026 = {
  sanchez: {
    name: "Roberto Sánchez",
    party: "Juntos por el Perú",
    votes: "En conteo (94%)",
    percentage: "50.015%",
    initials: "RS",
    color: "#81c995", // Google Green
    bgColor: "rgba(129, 201, 149, 0.12)",
    polymarketPrice: "4.4%",
    statusText: "Líder Técnico (ONPE)",
    statusType: "warning" as const
  },
  fujimori: {
    name: "Keiko Fujimori",
    party: "Fuerza Popular",
    votes: "En conteo (94%)",
    percentage: "49.985%",
    initials: "KF",
    color: "#8ab4f8", // Google Blue
    bgColor: "rgba(138, 180, 248, 0.12)",
    polymarketPrice: "95.5%",
    statusText: "Favorito (Polymarket)",
    statusType: "success" as const
  }
};
---

<Layout title="Contraste Electoral: Perú 2021 vs 2026 | Polymarket vs ONPE">
  
  <!-- Introduction & Overview -->
  <section class="overview-section">
    <div class="g-card-container">
      <h2 style="font-size: 1.5rem; color: #ffffff; margin-bottom: 12px; font-weight: 600;">Resumen del Análisis Electoral</h2>
      <p style="font-size: 1rem; line-height: 1.6; margin-bottom: 20px;">
        Perú experimenta por segunda vez consecutiva un escenario de <strong>empate técnico absoluto</strong> en una segunda vuelta presidencial. 
        Este tablero contrasta la votación histórica de hace 5 años (2021) con la coyuntura actual de 2026, revelando una notable divergencia 
        entre las actas contabilizadas oficialmente por la ONPE y la probabilidad de victoria especulada por los traders en <strong>Polymarket</strong>.
      </p>
      
      <div class="comparison-summary-grid">
        <div class="summary-stat-card">
          <span class="stat-year">2021</span>
          <div class="stat-row">
            <span class="stat-label">Margen de Victoria Fina:</span>
            <span class="stat-val color-red">0.25% (44,263 votos)</span>
          </div>
          <p class="stat-desc">Resolución tras semanas de apelaciones e impugnaciones electorales.</p>
        </div>
        <div class="summary-stat-card">
          <span class="stat-year">2026</span>
          <div class="stat-row">
            <span class="stat-label">Margen Actual (94%):</span>
            <span class="stat-val color-yellow">0.03% (~5,000 votos)</span>
          </div>
          <p class="stat-desc">Roberto Sánchez lidera el conteo oficial, pero Polymarket cotiza a Keiko Fujimori con 95.5% de probabilidad de ganar.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Live Update Action Panel -->
  <div class="g-card live-status-bar animated-fade-in" style="margin-bottom: 8px;">
    <div class="live-status-info">
      <span class="live-dot-container">
        <span class="live-dot"></span>
        <span class="live-dot-pulse"></span>
      </span>
      <div>
        <h4 style="font-size: 0.95rem; font-weight: 600; color: #ffffff;">Conexión de Datos en Vivo (Polymarket API)</h4>
        <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 2px;" id="update-timestamp">Última actualización: Cargado con datos iniciales</p>
      </div>
    </div>
    <button class="g-btn-live" id="btn-update-live">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="refresh-icon"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>
      <span>Actualizar Datos en Vivo</span>
    </button>
  </div>

  <!-- Side-by-Side Comparison -->
  <section class="grid-cols-2">
    
    <!-- 2021 Column -->
    <div class="g-card-container flex-col" style="background-color: var(--color-surface);">
      <div class="column-header">
        <span class="year-badge badge-gray">HACE 5 AÑOS</span>
        <h2 class="column-title">Elecciones 2021 (Finalizado)</h2>
        <p style="font-size: 0.85rem;">Segunda vuelta electoral del 6 de junio de 2021</p>
      </div>
      
      <div class="candidates-container flex-col">
        <CandidateCard 
          name={election2021.castillo.name}
          party={election2021.castillo.party}
          votes={election2021.castillo.votes}
          percentage={election2021.castillo.percentage}
          color={election2021.castillo.color}
          bgColor={election2021.castillo.bgColor}
          initials={election2021.castillo.initials}
          statusText={election2021.castillo.statusText}
          statusType={election2021.castillo.statusType}
        />
        
        <CandidateCard 
          name={election2021.fujimori.name}
          party={election2021.fujimori.party}
          votes={election2021.fujimori.votes}
          percentage={election2021.fujimori.percentage}
          color={election2021.fujimori.color}
          bgColor={election2021.fujimori.bgColor}
          initials={election2021.fujimori.initials}
          statusText={election2021.fujimori.statusText}
          statusType={election2021.fujimori.statusType}
        />
      </div>
      
      <div class="context-box">
        <h4>Contexto y Apuestas 2021:</h4>
        <p>
          Pedro Castillo comenzó como favorito (odds ~1.55, un ~60% de probabilidad). A finales de mayo, el alza de Keiko Fujimori en las encuestas revirtió la tendencia, colocándola como favorita en apuestas (odds ~1.75, un ~55% de probabilidad). En la noche electoral, su favoritismo saltó al 90% por la ventaja inicial urbana, pero se desplomó al entrar el conteo rural que proclamó ganador a Castillo.
        </p>
      </div>
    </div>
    
    <!-- 2026 Column -->
    <div class="g-card-container flex-col" style="background-color: var(--color-surface);">
      <div class="column-header">
        <span class="year-badge badge-blue">ELECCIÓN ACTUAL</span>
        <h2 class="column-title">Elecciones 2026 (En Progreso)</h2>
        <p style="font-size: 0.85rem;">Segunda vuelta electoral del 7 de junio de 2026</p>
      </div>
      
      <div class="candidates-container flex-col">
        <CandidateCard 
          name={election2026.sanchez.name}
          party={election2026.sanchez.party}
          votes={election2026.sanchez.votes}
          percentage={election2026.sanchez.percentage}
          color={election2026.sanchez.color}
          bgColor={election2026.sanchez.bgColor}
          initials={election2026.sanchez.initials}
          polymarketPrice={election2026.sanchez.polymarketPrice}
          statusText={election2026.sanchez.statusText}
          statusType={election2026.sanchez.statusType}
          priceId="price-sanchez-2026"
        />
        
        <CandidateCard 
          name={election2026.fujimori.name}
          party={election2026.fujimori.party}
          votes={election2026.fujimori.votes}
          percentage={election2026.fujimori.percentage}
          color={election2026.fujimori.color}
          bgColor={election2026.fujimori.bgColor}
          initials={election2026.fujimori.initials}
          polymarketPrice={election2026.fujimori.polymarketPrice}
          statusText={election2026.fujimori.statusText}
          statusType={election2026.fujimori.statusType}
          priceId="price-fujimori-2026"
        />
      </div>
      
      <div class="context-box">
        <h4>Contexto y Apuestas 2026:</h4>
        <p>
          El conteo oficial muestra una ventaja mínima de Sánchez al 94% (50.015% vs. 49.985%). Sin embargo, en Polymarket, Keiko Fujimori domina con 95.5%, reflejando que los apostadores anticipan que el ingreso del voto extranjero restante y los fallos de las 500,000 actas impugnadas por el JNE ratificarán su victoria.
        </p>
      </div>
    </div>
  </section>

  <!-- Polymarket Chart Section -->
  <section class="chart-section">
    <ElectionChart />
  </section>

  <!-- Deep Dive Analysis Section -->
  <section class="analysis-section g-card-container">
    <div style="border-left: 4px solid var(--g-yellow); padding-left: 16px; margin-bottom: 24px;">
      <h2 style="font-size: 1.5rem; color: #ffffff; font-weight: 600;">¿Por qué diverge la predicción del conteo en vivo?</h2>
      <p style="font-size: 0.9rem; color: var(--text-muted); margin-top: 4px;">Análisis de dinámicas de mercado frente a conteos de la ONPE</p>
    </div>
    
    <div class="analysis-grid">
      <div class="analysis-text-block">
        <h3 class="analysis-sub-title">1. El peso de las Actas Impugnadas</h3>
        <p>
          El principal factor de la aparente discrepancia radica en las **cerca de 500,000 actas impugnadas u observadas** que están pendientes de revisión por los Jurados Electorales Especiales (JEE) y el Jurado Nacional de Elecciones (JNE). Con una diferencia física de apenas 5,000 votos en el conteo en vivo, la resolución legal de estas actas decidirá el ganador. El mercado apuesta fuertemente a que Fuerza Popular prevalecerá en los fallos de estas impugnaciones.
        </p>
      </div>

      <div class="analysis-text-block">
        <h3 class="analysis-sub-title">2. Distribución del Voto Pendiente (Extranjero vs. Rural)</h3>
        <p>
          El conteo al 94% aún no integra la totalidad de las actas provenientes de consulados extranjeros y zonas rurales apartadas:
        </p>
        <ul style="margin-left: 20px; margin-top: 8px; color: var(--text-muted); line-height: 1.6;">
          <li>**Voto en el Extranjero:** Tiende a favorecer históricamente a Keiko Fujimori con márgenes de hasta 65% a 70%.</li>
          <li>**Voto de Selva y Zonas Andinas:** Tiende a favorecer a Roberto Sánchez. Sin embargo, los analistas de mercado evalúan que la proporción de votos extranjeros pendientes de ingresar compensará e incluso sobrepasará los márgenes rurales restantes.</li>
        </ul>
      </div>

      <div class="analysis-text-block">
        <h3 class="analysis-sub-title">3. Riesgo de Invalidez de la Elección</h3>
        <p>
          Existen mercados paralelos en Polymarket que evalúan la anulación o invalidación del proceso electoral antes de finales de junio de 2026. Varios candidatos de la primera vuelta presentaron solicitudes formales de nulidad por supuestos problemas logísticos en las mesas de votación. Aunque el JNE rechazó impugnaciones similares anteriormente, los especuladores integran la probabilidad de resoluciones complejas que terminen beneficiando políticamente a la candidatura de Fujimori.
        </p>
      </div>

      <div class="analysis-text-block bg-highlight">
        <h3 class="analysis-sub-title" style="color: var(--g-yellow);">Conclusión de los Datos</h3>
        <p>
          Mientras que en **2021** la tendencia del conteo rural avanzó lentamente hasta consolidar la victoria de Pedro Castillo por una fracción de punto (50.12%), en **2026** la presencia masiva de mercados de predicción en tiempo real como Polymarket permite cuantificar las expectativas de resolución institucional y votos en el extranjero, proyectando un desenlace altamente favorable a Fujimori (95.5% de probabilidad) a pesar del ajustado conteo doméstico actual.
        </p>
      </div>
    </div>
  </section>

</Layout>

<!-- Real-time Updates Script -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('btn-update-live');
    const timestamp = document.getElementById('update-timestamp');
    const sanchezPriceSpan = document.getElementById('price-sanchez-2026');
    const fujimoriPriceSpan = document.getElementById('price-fujimori-2026');

    if (!btn || !timestamp) return;

    async function fetchLiveOdds() {
      btn!.classList.add('loading');
      btn!.setAttribute('disabled', 'true');
      const textSpan = btn!.querySelector('span');
      if (textSpan) textSpan.textContent = 'Conectando con API...';

      try {
        const url = 'https://gamma-api.polymarket.com/public-search?q=Peru';
        const res = await fetch(url);
        if (!res.ok) throw new Error('API request failed');
        const data = await res.json();
        
        if (data.events && data.events.length > 0) {
          const event0 = data.events[0];
          if (event0.markets) {
            const kFujimori = event0.markets.find((m: any) => m.slug.includes('keiko-fujimori'));
            const rSanchez = event0.markets.find((m: any) => m.slug.includes('roberto-snchez'));
            
            let fPrice = 0.955; // defaults
            let sPrice = 0.044;
            
            if (kFujimori) {
              if (kFujimori.outcomePrices) {
                const prices = JSON.parse(kFujimori.outcomePrices);
                fPrice = parseFloat(prices[0]);
              } else if (kFujimori.lastTradePrice) {
                fPrice = parseFloat(kFujimori.lastTradePrice);
              }
              if (fujimoriPriceSpan) {
                fujimoriPriceSpan.textContent = `${(fPrice * 100).toFixed(1)}%`;
                fujimoriPriceSpan.classList.add('live-flash');
                setTimeout(() => fujimoriPriceSpan.classList.remove('live-flash'), 1000);
              }
            }
            
            if (rSanchez) {
              if (rSanchez.outcomePrices) {
                const prices = JSON.parse(rSanchez.outcomePrices);
                sPrice = parseFloat(prices[0]);
              } else if (rSanchez.lastTradePrice) {
                sPrice = parseFloat(rSanchez.lastTradePrice);
              }
              if (sanchezPriceSpan) {
                sanchezPriceSpan.textContent = `${(sPrice * 100).toFixed(1)}%`;
                sanchezPriceSpan.classList.add('live-flash');
                setTimeout(() => sanchezPriceSpan.classList.remove('live-flash'), 1000);
              }
            }
            
            // Dispatch live update to the SVG chart
            window.dispatchEvent(new CustomEvent('polymarket-live-update', { 
              detail: { fujimori: fPrice, sanchez: sPrice } 
            }));
            
            const now = new Date();
            timestamp!.textContent = `Última actualización en vivo: Hoy a las ${now.toLocaleTimeString('es-PE')}`;
            
            // Visual indicator success on the button
            if (textSpan) textSpan.textContent = '¡Datos Actualizados!';
            setTimeout(() => {
              if (textSpan) textSpan.textContent = 'Actualizar Datos en Vivo';
            }, 1500);
          }
        }
      } catch (err) {
        console.error("Error updating live prices:", err);
        timestamp!.textContent = "Error de red al actualizar. Reintente en un momento.";
        if (textSpan) textSpan.textContent = 'Reintentar actualización';
      } finally {
        setTimeout(() => {
          btn!.classList.remove('loading');
          btn!.removeAttribute('disabled');
        }, 500);
      }
    }

    btn.addEventListener('click', fetchLiveOdds);
  });
</script>

<style>
  /* Layout specific styles */
  .column-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 16px;
    margin-bottom: 16px;
  }
  
  .column-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #ffffff;
    margin-top: 8px;
  }
  
  .year-badge {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .badge-gray {
    background-color: var(--color-surface-variant);
    color: var(--text-muted);
  }
  
  .badge-blue {
    background-color: var(--g-blue-light);
    color: var(--g-blue);
    border: 1px solid rgba(138, 180, 248, 0.2);
  }
  
  .context-box {
    margin-top: 16px;
    background-color: var(--color-surface-container);
    border-radius: var(--border-radius-sm);
    padding: 16px;
    border: 1px solid var(--color-border);
  }
  
  .context-box h4 {
    font-size: 0.95rem;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 6px;
  }
  
  .context-box p {
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .comparison-summary-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 12px;
  }

  @media (max-width: 768px) {
    .comparison-summary-grid {
      grid-template-columns: 1fr;
    }
  }

  .summary-stat-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-md);
    padding: 20px;
  }

  .stat-year {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    color: #ffffff;
    display: block;
    margin-bottom: 8px;
  }

  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    font-size: 0.9rem;
  }

  .stat-label {
    color: var(--text-muted);
  }

  .stat-val {
    font-family: var(--font-display);
    font-weight: 700;
  }

  .stat-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .color-red {
    color: var(--g-red);
  }

  .color-yellow {
    color: var(--g-yellow);
  }

  /* Deep Dive Analysis styling */
  .analysis-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 12px;
  }

  @media (max-width: 900px) {
    .analysis-grid {
      grid-template-columns: 1fr;
    }
  }

  .analysis-text-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .analysis-sub-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #ffffff;
  }

  .bg-highlight {
    background-color: rgba(253, 214, 99, 0.05);
    border: 1px dashed rgba(253, 214, 99, 0.2);
    border-radius: var(--border-radius-md);
    padding: 20px;
  }

  /* Live status bar styling */
  .live-status-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    padding: 16px 24px;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .live-status-info {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .g-btn-live {
    background-color: var(--g-blue);
    color: #131314;
    border: none;
    border-radius: var(--border-radius-full);
    padding: 10px 20px;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    box-shadow: var(--shadow-sm);
    transition: var(--transition-fast);
  }

  .g-btn-live:hover {
    box-shadow: var(--shadow-md);
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .g-btn-live:active {
    transform: translateY(0);
  }

  .g-btn-live:disabled {
    filter: grayscale(0.4) opacity(0.8);
    cursor: not-allowed;
  }

  .g-btn-live.loading .refresh-icon {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Pulsing green dot */
  .live-dot-container {
    position: relative;
    width: 10px;
    height: 10px;
    display: inline-block;
    flex-shrink: 0;
  }

  .live-dot {
    position: absolute;
    width: 10px;
    height: 10px;
    background-color: var(--g-green);
    border-radius: 50%;
    z-index: 2;
  }

  .live-dot-pulse {
    position: absolute;
    width: 10px;
    height: 10px;
    background-color: var(--g-green);
    border-radius: 50%;
    animation: pulse 1.5s ease-out infinite;
    z-index: 1;
    opacity: 0.8;
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(3); opacity: 0; }
  }

  /* Highlight Flash Effect for updated spans */
  :global(.live-flash) {
    animation: flashGreen 1s ease-out;
  }

  @keyframes flashGreen {
    0% { color: var(--g-yellow); transform: scale(1.15); font-weight: 700; }
    100% { transform: scale(1); }
  }
</style>
